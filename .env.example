PORT=8000
HOST=127.0.0.1

# Twilio Credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio Sending Numbers
# E.g., whatsapp:+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# E.g., +1234567890
TWILIO_VOICE_NUMBER=

# Optional: WhatsApp Approved Template SID (Content SID)
TWILIO_WHATSAPP_TEMPLATE_SID=

# Public domain of your deployment (needed for verification and acceptance web links)
# E.g., https://saracare-ai.onrender.com or http://localhost:8000
PUBLIC_BASE_URL=http://localhost:8000

# Secret key used for signing tokens/hashes
CAREGIVER_TOKEN_SECRET=

# Database Connection URI (defaults to SQLite local db file if blank)
# E.g. for PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=
